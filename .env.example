# ── Tongyi / DashScope ──────────────────────────────────────────────────────
# 阿里云 DashScope API Key，前往 https://dashscope.console.aliyun.com 获取
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Embedding 模型 ID，需与 DashScope 控制台中的模型名称一致
# 常用值：text-embedding-v3 / text-embedding-v2 / multimodal-embedding-one-peace-v1
TONGYI_EMBEDDING_MODEL=text-embedding-v3

# ── Qdrant 向量数据库 ────────────────────────────────────────────────────────
# Qdrant 服务地址，本地 Docker 默认为 http://localhost:6333
QDRANT_URL=http://localhost:6333

# Qdrant API Key，云端部署时填写，本地部署留空即可
QDRANT_API_KEY=

# 默认 collection 名称，文档上传时未指定 collection 则使用此值
DEFAULT_COLLECTION=default

# ── 文件上传限制 ─────────────────────────────────────────────────────────────
# 单文件最大上传大小（单位 MB），超出将返回 HTTP 413
MAX_UPLOAD_SIZE_MB=50

# ── 检索参数 ──────────────────────────────────────────────────────────────────
# 相似度阈值（0~1），低于此值的结果不返回；值越高结果越精准但召回越少
SCORE_THRESHOLD=0.7

# 默认返回 top-k 结果数
TOP_K=5

# ── 文档分块参数 ──────────────────────────────────────────────────────────────
# 每个 chunk 的最大字符数
CHUNK_SIZE=1000

# 相邻 chunk 之间的重叠字符数，有助于保留跨 chunk 的上下文
CHUNK_OVERLAP=200
